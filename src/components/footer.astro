---
export interface Props {
  isDefault?: boolean;
  className?: string;
}

const { isDefault = false, className } = Astro.props;

const footerType = isDefault ? 'font-mono text-gray-700 text-sm text-center mx-8 md:mx-auto' : 'text-center';

const anchorClass = isDefault
  ? 'text-gray-700 hover:text-black rounded-full hover:bg-white py-1 px-2'
  : 'text-gray-500 hover:text-black rounded-full hover:bg-white py-1 px-2 no-underline';

const currentYear = new Date().getFullYear();
---

<footer class={className}>
  <div class={footerType}>
    <p>
      © 2012-{currentYear} Mrugesh Mohapatra Co. — All rights reserved.
    </p>
    <p class="mt-2">
      {
        !isDefault && (
          <>
            <a href="/" aria-label="Home" class={anchorClass}>
              Home
            </a>
            •
          </>
        )
      }
      <a href="/terms" aria-label="Terms & Conditions" class={anchorClass}> Terms </a>
      •
      <a href="/privacy" aria-label="Privacy Policy" class={anchorClass}> Privacy </a>
      •
      <a href="/refunds" aria-label="Refunds & Cancellation Policy" class={anchorClass}> Refunds </a>
      •
      <a href="/about" aria-label="Contact Us" class={anchorClass}> About & Contact </a>
    </p>
  </div>
</footer>
