---
// Skeleton loading component for blog cards
---

<div class="animate-pulse" data-testid="skeleton-block">
  <div class="relative aspect-video w-full bg-gray-200"></div>
  <div class="p-6 sm:p-10">
    <div class="mb-6 h-8 w-3/4 bg-gray-200"></div>
    <div class="space-y-4">
      {
        Array.from({ length: 6 }).map(() => (
          <div class="space-y-2">
            <div class="h-4 w-full bg-gray-200" />
            <div class="h-4 w-5/6 bg-gray-200" />
          </div>
        ))
      }
    </div>
  </div>
</div>
