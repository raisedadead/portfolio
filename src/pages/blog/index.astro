---
import MainLayout from '@/layouts/main-layout.astro';
import { Social } from '@/components/social';
import BlogPostCard from '@/components/blog-post-card';
import { getCollection } from 'astro:content';
import { cn } from '@/lib/utils';
import type { TransformedBlogPost } from '@/types/blog';
import { transformBlogPost } from '@/types/blog';

let posts: TransformedBlogPost[] = [];
let hasError = false;
let errorMessage = '';

try {
  const allPosts = await getCollection('blog');
  posts = allPosts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()).map(transformBlogPost);
} catch (error) {
  hasError = true;
  errorMessage = error instanceof Error ? error.message : 'Failed to load blog posts';
  console.error('Error loading blog posts:', error);
}
---

<MainLayout pageTitle='Recent posts' setCanonicalBlogBaseURL={true}>
  <section class={cn('mb-8')}>
    <div class={cn('prose prose-lg prose-slate max-w-none')}>
      <h1 class={cn('py-4 text-center text-3xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100')}>
        My Musings
      </h1>
    </div>
  </section>

  <section class={cn('mb-12')}>
    <div class={cn('mx-auto max-w-4xl')}>
      <p class={cn('pb-6 text-center text-lg font-medium text-slate-700 dark:text-slate-300')}>
        Stuff that I write about, mostly tech, sometimes life.
      </p>

      {
        hasError ? (
          <div
            class={cn(
              'border-2 border-black bg-white p-6 shadow-[4px_4px_0px_rgba(0,0,0,1)]',
              'transition-all duration-100 hover:shadow-[6px_6px_0px_rgba(0,0,0,1)]',
              'mx-auto my-8 max-w-2xl',
              'dark:border-white dark:bg-gray-800 dark:shadow-[4px_4px_0px_rgba(255,255,255,1)]'
            )}
          >
            <h2 class={cn('mb-4 text-center text-2xl font-bold text-red-800 dark:text-red-400')}>
              Oops! Something went wrong.
            </h2>
            <p class={cn('mb-4 text-lg text-slate-700 dark:text-slate-300')}>{errorMessage}</p>
            <p class={cn('text-slate-500 dark:text-slate-400')}>Sorry about this and thanks for your patience!</p>
          </div>
        ) : (
          <div id='blog-posts-grid' class={cn('grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-5')}>
            {posts.map((post, index) =>
              post.title && post.slug ? <BlogPostCard post={post} index={index} client:idle /> : null
            )}
          </div>
        )
      }
    </div>
  </section>

  <section>
    <div class={cn('prose prose-lg prose-slate mx-auto mt-8 max-w-3xl')}>
      <h3 class={cn('mb-4 text-center font-bold text-slate-700 dark:text-slate-300')}>Elsewhere on the internet</h3>
      <Social client:idle />
    </div>
  </section>
</MainLayout>
