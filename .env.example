# Single source of truth for all local secrets.
#
# Layout: copy to `.env` (gitignored) and fill the values that apply to you.
# Direnv (`.envrc`) auto-exports these into your shell on `cd` into the
# project so Astro/Vite, Wrangler, and pnpm scripts all see them.
# `pnpm develop` and `pnpm preview` regenerate `.dev.vars` from this file
# via `scripts/sync-dev-vars.mjs` (only the Worker-runtime subset).
#
# In CI / Cloudflare Workers Build:
#   - build-time vars (Turbo, Sentry, R2_*, PUBLIC_USE_R2_LOADER) -> Build env
#   - runtime secrets (CF_ACCESS_*, DEPLOY_HOOK_URL, DEV_BYPASS_ACCESS) ->
#     wrangler-managed secret store, per Worker

# --- Turborepo Remote Cache ---------------------------------------------- (build)
# Cloudflare Workers cache server URL (no trailing slash)
TURBO_API=
# Team name (must start with "team_")
TURBO_TEAM=team_portfolio
# Authentication token
TURBO_TOKEN=
# Cache signature key (generate with `openssl rand -base64 32`)
TURBO_REMOTE_CACHE_SIGNATURE_KEY=

# --- Sentry Error and Performance Monitoring ----------------------------- (build)
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=portfolio

# --- Cloudflare R2 - build-time loader ---------------------------------- (build)
# Read by Astro/Vite at `astro build` so the R2 content loader can fetch
# markdown from the bucket. NOT injected into the Worker env binding -
# build runs upstream of the Worker.
# Generate the API token: Cloudflare dashboard -> R2 -> Manage R2 API Tokens.
# Permission: object read on articles-content-* buckets is enough for builds;
# object read+write is required only when running scripts/migrate-articles-to-r2.mjs.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Endpoint: https://<account-id>.r2.cloudflarestorage.com (no slash, no bucket suffix)
R2_ENDPOINT=
# Bucket the build-time loader pulls from. Use articles-content-prd for prod, articles-content-stg otherwise.
R2_BUCKET_NAME=articles-content-stg

# --- Feature flag ------------------------------------------------------- (build)
# 1 (default behavior): switches the blog content collection to the R2 loader.
# 0: emergency rollback to local glob (vestigial after submodule removal).
# PUBLIC_ prefix exposes the flag to the Astro/Vite build.
PUBLIC_USE_R2_LOADER=1

# --- Worker runtime - Cloudflare Access (CMS) -------------------------- (runtime)
# These are the only keys mirrored into `.dev.vars` by sync-dev-vars.mjs.
# In production they land via the wrangler-managed secret store per Worker.
# NO `PUBLIC_` prefix - runtime-only, must never reach the client bundle.
#
# CF_ACCESS_TEAM_DOMAIN: full hostname, e.g. "<slug>.cloudflareaccess.com" (no scheme).
CF_ACCESS_TEAM_DOMAIN=
# CF_ACCESS_AUD: the per-application Audience tag (64-char hex) shown on the application overview page.
CF_ACCESS_AUD=
# Single-author allowlist. The JWT verifier rejects any other identity.
CF_ACCESS_AUTHOR_EMAIL=hi@mrugesh.dev
# Cloudflare Workers Build deploy hook URL. CMS publish action POSTs here to trigger redeploy.
DEPLOY_HOOK_URL=

# --- Worker runtime - dev escape hatch --------------------------------- (runtime)
# When set to 1 AND running in Astro DEV mode, the /admin gate skips JWT verification.
# Server-side only. Verifier hard-gates this on `import.meta.env.DEV` so prod
# builds ignore any non-zero value. Never commit a non-zero value here.
DEV_BYPASS_ACCESS=0
