# Turborepo Remote Cache Configuration
# Your Cloudflare Workers cache server URL (no trailing slash)
TURBO_API=
# Team name (must start with "team_")
TURBO_TEAM=team_portfolio
# Authentication token (same as set in Workers via wrangler secret put TURBO_TOKEN)
TURBO_TOKEN=
# Cache signature key (generate with: openssl rand -base64 32)
TURBO_REMOTE_CACHE_SIGNATURE_KEY=

# Sentry Error and Performance Monitoring
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=portfolio

# Cloudflare R2 — build-time loader
# Read by Astro/Vite at `astro build` so the R2 content loader can fetch markdown
# from the bucket. NOT used by Wrangler runtime (those secrets live in .dev.vars).
# In production: configure as Build environment variables in the CF Workers Builds dashboard.
#
# Generate the API token: Cloudflare dashboard -> R2 -> Manage R2 API Tokens.
# Permission: object read on the articles-content-* buckets is enough for builds.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com (no slash, no bucket suffix)
R2_ENDPOINT=
# Build-time bucket selection. Use articles-content-prd for prod builds, articles-content-stg otherwise.
R2_BUCKET_NAME=articles-content-stg

# Feature flag: 1 switches the blog content collection to the R2 loader (default 0 = local glob).
# PUBLIC_ prefix exposes the flag to the Astro/Vite build.
PUBLIC_USE_R2_LOADER=0
