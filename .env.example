# Single source of truth for all local secrets.
#
# Layout: copy to `.env` (gitignored) and fill the values that apply to you.
# Direnv (`.envrc`) auto-exports these into your shell on `cd` into the
# project so Astro/Vite, Wrangler, and pnpm scripts all see them.
#
# In CI / Cloudflare Workers Build:
#   - build-time vars (Turbo, Sentry, R2_*) -> Build env

# --- Turborepo Remote Cache ---------------------------------------------- (build)
# Cloudflare Workers cache server URL (no trailing slash)
TURBO_API=
# Team name (must start with "team_")
TURBO_TEAM=team_portfolio
# Authentication token
TURBO_TOKEN=
# Cache signature key (generate with `openssl rand -base64 32`)
TURBO_REMOTE_CACHE_SIGNATURE_KEY=

# --- Sentry Error and Performance Monitoring ----------------------------- (build)
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_ENVIRONMENT=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=portfolio

# --- Cloudflare R2 - build-time loader ---------------------------------- (build)
# Read by Astro/Vite at `astro build` so the R2 content loader can fetch
# markdown from the bucket. NOT injected into the Worker env binding -
# build runs upstream of the Worker.
# Generate the API token: Cloudflare dashboard -> R2 -> Manage R2 API Tokens.
# Permission: object read on articles-content-* buckets is enough for builds;
# object read+write is required only when running scripts/migrate-articles-to-r2.mjs.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Endpoint: https://<account-id>.r2.cloudflarestorage.com (no slash, no bucket suffix)
R2_ENDPOINT=
# Bucket the build-time loader pulls from. Use articles-content-prd for prod, articles-content-stg otherwise.
R2_BUCKET_NAME=articles-content-stg
