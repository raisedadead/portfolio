# Wrangler local-dev secrets (.dev.vars).
# Copy to `.dev.vars` (gitignored) and fill in real values for `wrangler dev` / `pnpm preview`.
# Production values land via `wrangler secret put <NAME>`.
#
# This file documents Worker-runtime secrets only. Build-time variables live in `.env`.
#
# Build-time roster (place these in `.env`, NOT here):
#   - R2_ACCESS_KEY_ID         # R2 API token id (read scope on articles-content-* buckets)
#   - R2_SECRET_ACCESS_KEY     # R2 API token secret
#   - R2_ENDPOINT              # https://<account-id>.r2.cloudflarestorage.com (no slash, no bucket suffix)
#   - R2_BUCKET_NAME           # articles-content-prd | articles-content-stg
#   - PUBLIC_USE_R2_LOADER     # 0 (default, glob loader) | 1 (R2 loader)
# Generate the API token in the Cloudflare dashboard: R2 → Manage R2 API Tokens → Create token (object read).

# --- CMS runtime (P4) -------------------------------------------------------
# Cloudflare Access self-hosted application that gates /admin/* and /api/cms/*.
# Discover via Zero Trust dashboard → Access → Applications → <app> → Overview.
#
# CF_ACCESS_TEAM_DOMAIN: full hostname, e.g. "mrugesh.cloudflareaccess.com" (no scheme).
CF_ACCESS_TEAM_DOMAIN=
# CF_ACCESS_AUD: the per-application AUD tag (UUID-like) shown on the application overview page.
CF_ACCESS_AUD=
# Single-author allowlist. The JWT verifier rejects any other identity.
CF_ACCESS_AUTHOR_EMAIL=hi@mrugesh.dev
# Cloudflare Workers Builds deploy hook URL. CMS publish action POSTs here to trigger redeploy.
DEPLOY_HOOK_URL=

# --- Dev-only escape hatch --------------------------------------------------
# When set to 1 AND running in Astro DEV mode, the /admin gate skips JWT verification.
# Server-side only — NO `PUBLIC_` prefix on purpose, so the value is never bundled
# into the client. The middleware reads it via the Worker `env` binding at request time.
# MUST stay unset (or 0) in any built artefact. CI verifies (V15).
# Never commit a real value here.
DEV_BYPASS_ACCESS=0
